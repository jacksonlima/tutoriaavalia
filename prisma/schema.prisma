// TutoriaAvalia v2
// Autor: Jackson Lima — CESUPA

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Papel {
  TUTOR
  ALUNO
}

enum TipoEncontro {
  ABERTURA
  FECHAMENTO
  FECHAMENTO_A
  FECHAMENTO_B
}

model Usuario {
  id           String   @id @default(uuid())
  email        String   @unique
  nome         String
  papel        Papel
  googleSub    String?  @unique @map("google_sub")
  avatarUrl    String?  @map("avatar_url")
  criadoEm    DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  modulosTutor         Modulo[]             @relation("Tutor")
  matriculas           Matricula[]
  avaliacoesTutor      AvaliacaoTutor[]
  avaliacoesFeitas     AvaliacaoAluno[]     @relation("Avaliador")
  avaliacoesRecebidas  AvaliacaoAluno[]     @relation("Avaliado")
  submissoes           Submissao[]
  notificacoes         Notificacao[]
  coTutorPerms         CoTutorPermissao[]
  janelasComoAluno     JanelaComplementar[] @relation("AlunoJanelaComplementar")
  janelasComoProfessor JanelaComplementar[] @relation("ProfessorJanelaComplementar")

  @@map("usuarios")
}

model Modulo {
  id        String  @id @default(uuid())
  nome      String
  ano       Int
  tutoria   String
  turma     String
  semestre  String  @default("01º Semestre")
  tutorId   String  @map("tutor_id")
  ativo     Boolean @default(true)
  arquivado Boolean @default(false)
  criadoEm    DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  tutor        Usuario            @relation("Tutor", fields: [tutorId], references: [id])
  matriculas   Matricula[]
  problemas    Problema[]
  coTutores    CoTutorPermissao[]
  notificacoes Notificacao[]

  @@unique([ano, tutoria, turma, tutorId])
  @@map("modulos")
}

model Matricula {
  id            String @id @default(uuid())
  moduloId      String @map("modulo_id")
  usuarioId     String @map("usuario_id")
  numeraNaTurma Int    @map("numero_na_turma")

  modulo  Modulo  @relation(fields: [moduloId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@unique([moduloId, usuarioId])
  @@unique([moduloId, numeraNaTurma])
  @@map("matriculas")
}

model Problema {
  id               String  @id @default(uuid())
  moduloId         String  @map("modulo_id")
  numero           Int
  nome             String?
  aberturaAtiva    Boolean @default(false) @map("abertura_ativa")
  fechamentoAtivo  Boolean @default(false) @map("fechamento_ativo")
  temSaltoTriplo   Boolean @default(false) @map("tem_salto_triplo")
  fechamentoAAtivo Boolean @default(false) @map("fechamento_a_ativo")
  fechamentoBAtivo Boolean @default(false) @map("fechamento_b_ativo")

  modulo               Modulo               @relation(fields: [moduloId], references: [id])
  avaliacoesTutor      AvaliacaoTutor[]
  avaliacoesAluno      AvaliacaoAluno[]
  submissoes           Submissao[]
  coTutorPerms         CoTutorPermissao[]
  situacoesExcepcionaisOrigem  SituacaoExcepcional[] @relation("SituacoesExcepcionaisOrigem")
  situacoesExcepcionaisDestino SituacaoExcepcional[] @relation("SituacoesExcepcionaisDestino")
  janelasComplementares        JanelaComplementar[]

  @@unique([moduloId, numero])
  @@map("problemas")
}

model AvaliacaoTutor {
  id                String       @id @default(uuid())
  problemaId        String       @map("problema_id")
  avaliadoId        String       @map("avaliado_id")
  tutorId           String       @map("tutor_id")
  tipoEncontro      TipoEncontro @map("tipo_encontro")
  c1                Decimal      @db.Decimal(3, 1)
  c2                Decimal      @db.Decimal(3, 1)
  c3                Decimal      @db.Decimal(3, 1)
  atitudes          Decimal      @db.Decimal(3, 1)
  ativCompensatoria Boolean      @default(false) @map("ativ_compensatoria")
  faltou            Boolean      @default(false)
  finalizado        Boolean      @default(false)
  finalizadoEm      DateTime?    @map("finalizado_em")
  criadoEm         DateTime     @default(now()) @map("criado_em")
  atualizadoEm     DateTime     @updatedAt @map("atualizado_em")

  problema Problema @relation(fields: [problemaId], references: [id])
  avaliado Usuario  @relation(fields: [avaliadoId], references: [id])

  @@unique([problemaId, avaliadoId, tipoEncontro])
  @@map("avaliacoes_tutor")
}

model AvaliacaoAluno {
  id           String       @id @default(uuid())
  problemaId   String       @map("problema_id")
  avaliadorId  String       @map("avaliador_id")
  avaliadoId   String       @map("avaliado_id")
  tipoEncontro TipoEncontro @map("tipo_encontro")
  c1           Decimal      @db.Decimal(3, 1)
  c2           Decimal      @db.Decimal(3, 1)
  c3           Decimal      @db.Decimal(3, 1)
  atitudes     Decimal      @db.Decimal(3, 1)
  criadoEm    DateTime     @default(now()) @map("criado_em")
  atualizadoEm DateTime     @updatedAt @map("atualizado_em")

  problema  Problema @relation(fields: [problemaId], references: [id])
  avaliador Usuario  @relation("Avaliador", fields: [avaliadorId], references: [id])
  avaliado  Usuario  @relation("Avaliado", fields: [avaliadoId], references: [id])

  @@unique([problemaId, avaliadorId, avaliadoId, tipoEncontro])
  @@map("avaliacoes_aluno")
}

model Submissao {
  id           String       @id @default(uuid())
  problemaId   String       @map("problema_id")
  avaliadorId  String       @map("avaliador_id")
  tipoEncontro TipoEncontro @map("tipo_encontro")
  submetidoEm  DateTime     @default(now()) @map("submetido_em")
  ipOrigem     String?      @map("ip_origem")
  userAgent    String?      @map("user_agent")

  problema  Problema @relation(fields: [problemaId], references: [id])
  avaliador Usuario  @relation(fields: [avaliadorId], references: [id])

  @@unique([problemaId, avaliadorId, tipoEncontro])
  @@map("submissoes")
}

model CoTutorPermissao {
  id         String   @id @default(uuid())
  moduloId   String   @map("modulo_id")
  tutorId    String   @map("tutor_id")
  problemaId String?  @map("problema_id")
  criadoEm  DateTime @default(now()) @map("criado_em")

  modulo   Modulo    @relation(fields: [moduloId], references: [id])
  tutor    Usuario   @relation(fields: [tutorId], references: [id])
  problema Problema? @relation(fields: [problemaId], references: [id])

  @@unique([moduloId, tutorId, problemaId])
  @@map("co_tutor_permissoes")
}

model Notificacao {
  id        String    @id @default(uuid())
  usuarioId String    @map("usuario_id")
  moduloId  String?   @map("modulo_id")
  tipo      String
  titulo    String
  mensagem  String
  lida      Boolean   @default(false)
  criadaEm DateTime  @default(now()) @map("criada_em")
  lidaEm   DateTime? @map("lida_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  modulo  Modulo? @relation(fields: [moduloId], references: [id])

  @@map("notificacoes")
}

model SituacaoExcepcional {
  id                String       @id @default(uuid())
  problemaOrigemId  String       @map("problema_origem_id")
  problemaDestinoId String       @map("problema_destino_id")
  tipoEncontro      TipoEncontro @map("tipo_encontro")
  motivo            String?
  criadoEm         DateTime     @default(now()) @map("criado_em")

  problemaOrigem  Problema @relation("SituacoesExcepcionaisOrigem",  fields: [problemaOrigemId],  references: [id])
  problemaDestino Problema @relation("SituacoesExcepcionaisDestino", fields: [problemaDestinoId], references: [id])

  @@map("situacoes_excepcionais")
}

model JanelaComplementar {
  id           String       @id @default(uuid())
  problemaId   String       @map("problema_id")
  alunoId      String       @map("aluno_id")
  tipoEncontro TipoEncontro @map("tipo_encontro")
  aberta       Boolean      @default(true)
  criadaPorId  String       @map("criada_por_id")
  criadaEm    DateTime     @default(now()) @map("criada_em")
  fechadaEm   DateTime?    @map("fechada_em")

  problema  Problema @relation(fields: [problemaId], references: [id], onDelete: Cascade)
  aluno     Usuario  @relation("AlunoJanelaComplementar",     fields: [alunoId],     references: [id], onDelete: Cascade)
  criadaPor Usuario  @relation("ProfessorJanelaComplementar", fields: [criadaPorId], references: [id])

  @@unique([problemaId, alunoId, tipoEncontro])
  @@map("janelas_complementares")
}

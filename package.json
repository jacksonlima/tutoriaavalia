{
  "name": "tutoriaavalia",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate",
    "db:seed:intro": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed-intro-medicina.ts",
    "db:seed:ataque": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed-ataque-defesa.ts",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^6.0.0",
    "@tanstack/react-query": "^5.62.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "next": "^16.2.3",
    "next-auth": "^5.0.0-beta.22",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.9.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^7.4.0",
    "postcss": "^8.4.49",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.15",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  },
  "author": "Jackson Lima <jackson.lima@prof.cesupa.br>",
  "description": "Sistema de avaliação formativa para Aprendizagem Baseada em Problemas (ABP) — CESUPA"
}

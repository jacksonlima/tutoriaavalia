# TutoriaAvalia v2 — Ambiente de Testes
# Autor: Jackson Lima — CESUPA
#
# Para criar o banco de teste localmente:
#   createdb tutoriaavalia_test
#   DATABASE_URL="..." npx prisma migrate deploy

DATABASE_URL=postgresql://test:test@localhost:5432/tutoriaavalia_test
DIRECT_DATABASE_URL=postgresql://test:test@localhost:5432/tutoriaavalia_test
NEXTAUTH_SECRET=secret-apenas-para-testes-nao-usar-em-producao
AUTH_TRUST_HOST=true
ALLOWED_EMAIL_DOMAIN=

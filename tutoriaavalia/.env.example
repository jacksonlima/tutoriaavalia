# ─────────────────────────────────────────────────────────────────
# TutoriaAvalia v2 — Variáveis de Ambiente (Desenvolvimento Local)
# Autor: Jackson Lima — CESUPA
# ─────────────────────────────────────────────────────────────────
# ATENÇÃO: Este arquivo NÃO deve ser enviado para o GitHub.
# Ele já está listado no .gitignore.
# ─────────────────────────────────────────────────────────────────

# ── Google OAuth ─────────────────────────────────────────────────
# Obtenha em: https://console.cloud.google.com → APIs → Credenciais
GOOGLE_CLIENT_ID=SEU_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=SEU_CLIENT_SECRET

# ── NextAuth ─────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=GERE_COM_OPENSSL_RAND_BASE64_32
# NEXTAUTH_URL: NÃO definir em desenvolvimento quando usar ngrok ou IP local.
# Com AUTH_TRUST_HOST=true o NextAuth detecta o host automaticamente.
# Defina SOMENTE em produção (Vercel):
# NEXTAUTH_URL=https://tutoriaavalia.vercel.app
AUTH_TRUST_HOST=true

# ── Banco de dados Neon ──────────────────────────────────────────
# URL com pooler (para queries em runtime)
DATABASE_URL=postgresql://USER:SENHA@ep-xxx-pooler.sa-east-1.aws.neon.tech/tutoriaavalia?sslmode=require

# URL direta sem pooler (para migrations e prisma db push)
DIRECT_DATABASE_URL=postgresql://USER:SENHA@ep-xxx.sa-east-1.aws.neon.tech/tutoriaavalia?sslmode=require

# ── Controle de acesso ───────────────────────────────────────────
# Domínios permitidos para login Google (separados por vírgula)
# prof.cesupa.br → TUTOR automaticamente
# aluno.cesupa.br → ALUNO automaticamente
# Deixe vazio para aceitar qualquer email Google (útil para testes)
ALLOWED_EMAIL_DOMAIN=prof.cesupa.br,aluno.cesupa.br

# ──────────────────────────────────────────────────────────────────
# TutoriaAvalia v2 — Variáveis de Ambiente
# 1. Copie: cp .env.example .env.local
# 2. Preencha TODOS os valores abaixo
# 3. NUNCA commite .env.local no Git
# ──────────────────────────────────────────────────────────────────

# ── Google OAuth ──────────────────────────────────────────────────
# Obtenha em: console.cloud.google.com → Credenciais → OAuth 2.0
GOOGLE_CLIENT_ID=cole-seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=cole-seu-client-secret

# ── NextAuth ──────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=gere-uma-string-aleatoria-aqui
NEXTAUTH_URL=http://localhost:3000

# ── Supabase / PostgreSQL ─────────────────────────────────────────
# Obtido em: supabase.com → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.XXXX.supabase.co:5432/postgres

# ── Domínio institucional ─────────────────────────────────────────
# IMPORTANTE: deve ser EXATAMENTE a parte após o @ do email institucional
# Exemplos:
#   professor@prof.cesupa.br   → ALLOWED_EMAIL_DOMAIN=prof.cesupa.br
#   aluno@aluno.cesupa.br      → use o domínio que todos os usuários têm
#   Se deixar VAZIO, qualquer email Google pode fazer login (só para testes!)
ALLOWED_EMAIL_DOMAIN=prof.cesupa.br

# Para múltiplos domínios, separe por vírgula:
# ALLOWED_EMAIL_DOMAIN=prof.cesupa.br,gmail.com
ALLOWED_EMAIL_DOMAIN=prof.cesupa.br,gmail.com
